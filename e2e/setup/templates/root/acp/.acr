# Restrictive server root ACR.
#
# The root container itself is publicly readable (server intro page),
# but NO memberAccessControl is set, so pods rely exclusively on
# their own ACRs for authorization.
@prefix acl: <http://www.w3.org/ns/auth/acl#>.
@prefix acp: <http://www.w3.org/ns/solid/acp#>.

<#root>
    a acp:AccessControlResource;
    acp:resource <./>;
    acp:accessControl <#publicReadRoot>.

<#publicReadRoot>
    a acp:AccessControl;
    acp:apply [
        a acp:Policy;
        acp:allow acl:Read;
        acp:anyOf [
            a acp:Matcher;
            acp:agent acp:PublicAgent
        ]
    ].

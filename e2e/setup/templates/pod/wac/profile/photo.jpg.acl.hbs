# ACL resource for the profile photo
@prefix acl: <http://www.w3.org/ns/auth/acl#>.
@prefix foaf: <http://xmlns.com/foaf/0.1/>.

# The profile photo is readable by the public.
<#public>
    a acl:Authorization;
    acl:agentClass foaf:Agent;
    acl:accessTo <./photo.jpg>;
    acl:mode acl:Read.

# The owner has full access to the photo
<#owner>
    a acl:Authorization;
    acl:agent <{{webId}}>;
    acl:accessTo <./photo.jpg>;
    acl:mode acl:Read, acl:Write, acl:Control.

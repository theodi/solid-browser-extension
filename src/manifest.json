{
  "manifest_version": 3,
  "name": "Solid Browser Extension",
  "version": "0.1.0",
  "description": "Authenticate with Solid at the browser level",
  "permissions": [
    "storage",
    "activeTab",
    "identity"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Solid Login"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["inject/inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content/content-script.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["redirect/redirect.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
